root = true

# Default for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown — preserve trailing spaces (used for line breaks)
[*.md]
trim_trailing_whitespace = false

# Makefiles require tabs
[Makefile]
indent_style = tab

# Go requires tabs
[*.go]
indent_style = tab
indent_size = 4

# Python convention
[*.py]
indent_size = 4

# Java / Kotlin convention
[*.{java,kt}]
indent_size = 4

# C# convention
[*.cs]
indent_size = 4

# Shell scripts
[*.sh]
indent_size = 2
