{
  "permissions": {
    "allow": [
      "Edit(/.claude/**)",
      "Bash(./**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/git-guard.sh"
          }
        ]
      }
    ]
  }
}
